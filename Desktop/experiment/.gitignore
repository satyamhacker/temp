# ========================
# 1. Virtual Environments
# ========================
# Inko kabhi push nahi karna chahiye, har developer ka apna alag hota hai
.venv/
venv/
env/
ENV/

# ========================
# 2. Python Cache Files
# ========================
# Python run hote waqt jo background kachra banata hai
__pycache__/
*.py[cod]
*$py.class

# ========================
# 3. IDEs and Editor Folders
# ========================
# Tere personal editor ki settings
.vscode/
.idea/
.qodo/

# ========================
# 4. Logs and Environment Variables
# ========================
# API keys aur error logs ko safe rakhne ke liye
*.log
.env

# ========================
# 5. OS Generated Files
# ========================
.DS_Store
Thumbs.db